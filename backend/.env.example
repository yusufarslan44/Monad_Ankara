# ─── Sunucu ───────────────────────────────────────────────────────────────
PORT=4000

# Gelistirme kolayligi: ayarliysa dogrulama kodu daima bu deger olur (orn. 123456).
# Uretimde BOS birakin ki rastgele kod uretilsin.
DEV_FIXED_CODE=

# ─── MongoDB Atlas ──────────────────────────────────────────────────────────
# Gercek deger .env'de tutulur, commit edilmez.
MONGO_URI=

# ─── Monad Testnet / Zincir ─────────────────────────────────────────────────
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
# StudentID kontratina register() cagiran admin cuzdaninin private key'i.
# StudentID constructor'inda admin olarak verilen adresle ayni olmali.
ADMIN_PRIVATE_KEY=0xADMIN_PRIVATE_KEY_BURAYA
# StudentID kontrat adresi. Bos birakilirsa shared/deployments/monad-testnet.json kullanilir.
STUDENT_ID_ADDRESS=

# ─── SMTP (nodemailer) ──────────────────────────────────────────────────────
# Bos birakilirsa dogrulama kodu e-posta yerine sunucu konsoluna yazilir (dev modu).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Monad Kampus <no-reply@monadkampus.xyz>"
